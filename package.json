{
  "name": "mintlify-astro-starter",
  "type": "module",
  "version": "1.0.0",
  "description": "An Astro starter kit for building custom documentation sites powered by Mintlify.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mintlify/mintlify-astro-starter.git"
  },
  "homepage": "https://github.com/mintlify/mintlify-astro-starter#readme",
  "bugs": {
    "url": "https://github.com/mintlify/mintlify-astro-starter/issues"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler pages dev ./dist",
    "deploy": "astro build && wrangler pages deploy ./dist",
    "astro": "astro",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.70",
    "@astrojs/mdx": "^4.3.1",
    "@astrojs/react": "^4.4.2",
    "@mintlify/astro": "^0.1.9",
    "@mintlify/components": "^1.0.5",
    "@mintlify/models": "^0.0.260",
    "@mintlify/validation": "^0.1.574",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.1.18",
    "ai": "^6.0.68",
    "ajv": "^8.17.1",
    "astro": "^5.16.12",
    "mini-svg-data-uri": "^1.4.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^10.1.0",
    "tailwindcss": "^4.1.18",
    "use-debounce": "^10.1.0",
    "zustand": "^5.0.11"
  },
  "overrides": {
    "ajv": "^8.17.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.24.0",
    "eslint": "^9.20.0",
    "eslint-plugin-astro": "^1.3.1",
    "prettier": "^3.5.3",
    "prettier-plugin-astro": "^0.14.1",
    "wrangler": "^3.0.0"
  }
}
