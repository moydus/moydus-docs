# Assistant uses /api/chat (Cloudflare Pages Function + Workers AI)
# Search uses /api/search (D1) with fallback to public/search-index.json
#
# Local dev with Functions:
#   npm run build && npm run preview
#
# Optional overrides:
# PUBLIC_AI_API_URL=/api/chat
# PUBLIC_SEARCH_API_URL=/api/search
# PUBLIC_SITE_ID=docfiy-ornek
