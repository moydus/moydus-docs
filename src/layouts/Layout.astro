---
import { ClientRouter } from 'astro:transitions';
import { AssistantSheet, AssistantProvider } from '../components/Assistant';
import { MobileAskBar } from '../components/MobileAskBar';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Moydus Docs', description } = Astro.props;
const fullTitle = title.includes('Moydus') ? title : `${title} | Moydus`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <!-- Dark mode init: runs before paint to prevent flash -->
    <script is:inline>
      (function() {
        var saved = localStorage.getItem('theme');
        if (saved === 'dark') {
          document.documentElement.classList.add('dark');
        } else if (saved === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches) {
          document.documentElement.classList.add('dark');
        }
        // No saved preference → default light mode
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,500;1,600;1,700;1,800&family=JetBrains+Mono:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <ClientRouter />
  </head>
  <body class="bg-white dark:bg-[#0e0e0f] text-gray-900 dark:text-gray-100">
    <AssistantProvider client:only="react" />
    <div class="flex antialiased">
      <div class="flex-1 min-w-0 max-w-[1400px] mx-auto w-full">
        <slot />
      </div>
      <AssistantSheet client:only="react" transition:persist />
    </div>
    <MobileAskBar client:only="react" />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    overscroll-behavior-y: none;
  }

  ::view-transition-old(*),
  ::view-transition-new(*),
  ::view-transition-group(*) {
    animation-duration: 0s !important;
  }
</style>
