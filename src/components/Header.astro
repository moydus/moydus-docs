---
import type { TabInfo } from '@mintlify/astro/helpers';
import { SearchBar } from './SearchBar';
import { MobileActionButtons, MobileNavToggle } from './MobileHeaderActions';

interface Props {
  tabs: TabInfo[] | null;
  pageTitle?: string;
  groupName?: string;
}

const { tabs, pageTitle, groupName } = Astro.props;
const usingTabs = tabs && tabs.length > 0;
---

<header id="navbar" class="z-30 fixed lg:sticky top-0 w-full">
  <!-- Border overlay -->
  <div class="z-10 absolute w-full h-full border-b border-gray-100 dark:border-gray-800 pointer-events-none"></div>
  <!-- Background -->
  <div class="z-0 absolute inset-0 bg-white/95 dark:bg-[#0e0e0f]/95 backdrop-blur pointer-events-none transition-colors"></div>

  <div class="z-10 relative mx-auto max-w-8xl px-0 lg:px-5">
    <div class="relative">

      <!-- Main header row -->
      <div class="flex items-center h-14 min-w-0 mx-4 lg:mx-0 lg:px-4">
        <div class="h-full relative flex-1 flex items-center gap-x-4 min-w-0">

          <!-- Left: Logo + name -->
          <div class="flex-1 flex items-center gap-x-4">
            <a href="/" class="select-none flex items-center gap-2 shrink-0">
              <span class="sr-only">Moydus home page</span>
              <img src="/logo/light.svg" alt="Moydus" class="h-6 w-auto block dark:hidden object-contain" />
              <img src="/logo/dark.svg" alt="Moydus" class="h-6 w-auto hidden dark:block object-contain" />
              <span class="font-semibold text-gray-900 dark:text-white text-[15px] tracking-tight">Moydus</span>
            </a>
          </div>

          <!-- Center: Search -->
          <div class="relative hidden lg:flex items-center flex-1 z-20 justify-center">
            <div class="w-full max-w-sm">
              <SearchBar client:load />
            </div>
          </div>

          <!-- Right: Nav links + theme toggle -->
          <div class="hidden lg:flex flex-1 items-center gap-2 justify-end">
            <!-- Ask Assistant button -->
            <button
              type="button"
              class="group/ai flex-none hidden lg:flex items-center justify-center gap-1.5 pl-3 pr-3.5 h-9 rounded-xl bg-background-light dark:bg-background-dark dark:brightness-[1.1] dark:ring-1 dark:hover:brightness-[1.25] ring-1 ring-gray-400/30 hover:ring-gray-600/30 dark:ring-gray-600/30 dark:hover:ring-gray-500/30"
              id="assistant-entry"
              aria-label="Toggle assistant panel"
              data-state="closed"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false" class="size-4 shrink-0 text-gray-700 group-hover/ai:text-gray-800 dark:text-gray-400 dark:group-hover/ai:text-gray-200">
                <path d="M5.65799 2.99L4.39499 2.569L3.97399 1.306C3.83699 0.898 3.16199 0.898 3.02499 1.306L2.60399 2.569L1.34099 2.99C1.13699 3.058 0.998993 3.249 0.998993 3.464C0.998993 3.679 1.13699 3.87 1.34099 3.938L2.60399 4.359L3.02499 5.622C3.09299 5.826 3.28499 5.964 3.49999 5.964C3.71499 5.964 3.90599 5.826 3.97499 5.622L4.39599 4.359L5.65899 3.938C5.86299 3.87 6.00099 3.679 6.00099 3.464C6.00099 3.249 5.86199 3.058 5.65799 2.99Z" fill="currentColor" stroke="none"></path>
                <path d="M9.5 2.75L11.412 7.587L16.25 9.5L11.412 11.413L9.5 16.25L7.587 11.413L2.75 9.5L7.587 7.587L9.5 2.75Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
              <span class="text-sm text-gray-500 dark:text-white/50 whitespace-nowrap">Ask Assistant</span>
            </button>

            <nav aria-label="Main" class="text-sm">
              <ul class="flex gap-1 items-center">
                <li class="navbar-link">
                  <a
                    href="mailto:support@moydus.com"
                    class="flex items-center whitespace-nowrap font-medium gap-2 text-gray-800 dark:text-gray-50 hover:text-gray-800 dark:hover:text-gray-50 bg-gray-950/[0.03] dark:bg-white/[0.03] hover:bg-gray-950/10 dark:hover:bg-white/10 rounded-xl px-[14px] py-2 transition-colors text-sm"
                  >
                    <span class="min-w-0 truncate">Support</span>
                  </a>
                </li>
                <li class="navbar-link">
                  <a
                    href="https://moydus.com"
                    target="_blank"
                    class="flex items-center whitespace-nowrap font-medium gap-2 text-white bg-[#ff4d00] hover:bg-[#e04400] rounded-xl px-[14px] py-2 transition-colors text-sm"
                  >
                    <span class="min-w-0 truncate">Get started</span>
                  </a>
                </li>
              </ul>
            </nav>

            <!-- Dark mode toggle -->
            <button
              id="theme-toggle"
              class="group p-2 flex items-center justify-center w-[30px] h-[30px] rounded-full bg-gray-900/[0.04] dark:bg-white/10 hover:bg-gray-900/10 dark:hover:bg-white/20 transition-colors cursor-pointer"
              aria-label="Toggle dark mode"
            >
              <!-- Sun icon (light mode) -->
              <svg class="size-4 block dark:hidden text-gray-600 group-hover:text-gray-800" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1.5M12 19.5V21M4.219 4.219l1.061 1.061M17.72 17.72l1.06 1.06M3 12h1.5M19.5 12H21M4.219 19.781l1.061-1.061M17.72 6.28l1.06-1.061M12 7.5a4.5 4.5 0 1 1 0 9 4.5 4.5 0 0 1 0-9z" />
              </svg>
              <!-- Moon icon (dark mode) -->
              <svg class="size-4 hidden dark:block text-gray-300 group-hover:text-gray-100" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z" />
              </svg>
            </button>
          </div>

          <!-- Mobile: search + ellipsis -->
          <MobileActionButtons client:load />
        </div>
      </div>

      <!-- Mobile nav toggle banner -->
      {
        pageTitle && (
          <MobileNavToggle
            pageTitle={pageTitle}
            groupName={groupName}
            client:load
          />
        )
      }
    </div>

    <!-- Tab navigation row (desktop) -->
    {
      usingTabs && (
        <div class="hidden lg:flex px-4 h-10">
          <div class="nav-tabs h-full flex text-sm gap-x-6">
            {tabs.map((tab) => (
              <a
                href={tab.href}
                class:list={[
                  'nav-tabs-item group relative h-full gap-2 flex items-center font-medium transition-colors',
                  tab.isActive
                    ? 'text-gray-900 dark:text-white [text-shadow:-0.2px_0_0_currentColor,0.2px_0_0_currentColor]'
                    : 'text-gray-600 dark:text-gray-400 hover:text-gray-800 dark:hover:text-gray-200',
                ]}
                aria-current={tab.isActive ? 'location' : undefined}
              >
                {tab.name}
                <div
                  class:list={[
                    'absolute bottom-0 h-px w-full left-0',
                    tab.isActive
                      ? 'bg-(--primary)'
                      : 'group-hover:bg-gray-200 dark:group-hover:bg-gray-700',
                  ]}
                />
              </a>
            ))}
          </div>
        </div>
      )
    }
  </div>
</header>

<script is:inline>
  function initAssistantEntry() {
    const btn = document.getElementById('assistant-entry');
    if (!btn) return;
    const fresh = btn.cloneNode(true);
    btn.parentNode.replaceChild(fresh, btn);
    fresh.addEventListener('click', function() {
      window.dispatchEvent(new CustomEvent('assistant:toggle'));
    });
  }
  document.addEventListener('astro:page-load', initAssistantEntry);
  initAssistantEntry();
</script>

<script is:inline>
  function initThemeToggle() {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;
    // Remove old listener by cloning
    const fresh = btn.cloneNode(true);
    btn.parentNode.replaceChild(fresh, btn);
    fresh.addEventListener('click', function() {
      const isDark = document.documentElement.classList.toggle('dark');
      try { localStorage.setItem('theme', isDark ? 'dark' : 'light'); } catch(e) {}
    });
  }
  // Run on initial load and after every Astro page navigation
  document.addEventListener('astro:page-load', initThemeToggle);
  initThemeToggle();
</script>
